{
  "name": "tongue-web-workspace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:user": "npm --workspace @tongue/user-web run dev",
    "dev:doctor": "npm --workspace @tongue/doctor-web run dev",
    "dev:admin": "npm --workspace @tongue/admin-web run dev",
    "build": "npm --workspaces --if-present run build",
    "build:user": "npm --workspace @tongue/user-web run build",
    "build:doctor": "npm --workspace @tongue/doctor-web run build",
    "build:admin": "npm --workspace @tongue/admin-web run build",
    "typecheck": "npm --workspaces --if-present run typecheck"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "echarts": "^5.6.0",
    "element-plus": "^2.9.6",
    "lucide-vue-next": "^0.468.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "vue-tsc": "^2.2.0"
  }
}
